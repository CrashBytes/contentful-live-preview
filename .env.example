# Contentful Configuration
# Copy this file to .env.local and fill in your actual values
# Or run ./install.sh for an interactive setup wizard

# Space Configuration
CONTENTFUL_SPACE_ID=your_space_id_here
CONTENTFUL_ENVIRONMENT=master

# API Tokens
# Get these from: Contentful → Settings → API keys
CONTENTFUL_DELIVERY_TOKEN=your_delivery_token_here
CONTENTFUL_PREVIEW_TOKEN=your_preview_token_here

# Preview API Security
# Use a random string to secure your preview endpoint
# Generate one with: openssl rand -hex 32
CONTENTFUL_PREVIEW_SECRET=your_random_secret_here

# Public Environment Variables
# These are exposed to the browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_CONTENTFUL_SPACE_ID=your_space_id_here
NEXT_PUBLIC_CONTENTFUL_ENVIRONMENT=master
